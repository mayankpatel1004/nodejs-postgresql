  function fnCalculateDiscount(discount_percentage) {
    let calculate_discount = parseFloat($("#GROSS_TOTAL").val()) - parseFloat($("#SCHEME1_TOTAL").val()) - parseFloat($("#SCHEME2_TOTAL").val());
    let discount_amount = parseFloat(calculate_discount) * (parseFloat(discount_percentage) / 100);
    $("#DISCOUNT_AMOUNT").val(discount_amount.toFixed(2));

    $('#sampleTable > tbody  > tr').each(function (index, tr) {
      let final_row_tax_amount = 0;
      let id = tr.id;
      let is_dmg_calculation = 0;
      if (typeof id !== undefined && id != "") {
        let split_id = id.split("_");
        let row_id = parseInt(split_id[1]) + parseInt(0);

        let insurance_amt = 0;
        let product_amt = parseFloat($("#rw_" + row_id + " .AMT").val());
        let scheme1_amount = parseFloat($("#rw_" + row_id + " .SCHEME1_AMOUNT").val());
        let scheme2_amount = parseFloat($("#rw_" + row_id + " .SCHEME2_AMOUNT").val());
        let insurance_vat = parseFloat($("#rw_" + row_id + " .PUR_INSURANCE").val());
        let tax_percent_nonnumeric = $("#rw_" + row_id + " .TAX_PER").html();
        const tax_percent = removeNonNumeric(tax_percent_nonnumeric);

        if(parseInt(insurance_vat) > 0){
          if ($(".unique_sales, .unique_purchase, .unique_salesreturn").length) {
            insurance_amt = (parseFloat(product_amt) * parseFloat(insurance_vat)) / 100;
          }
        }
        
        let row_discount = parseFloat(product_amt) - parseFloat(scheme1_amount) - parseFloat(scheme2_amount);
        let row_discount_amt = parseFloat(row_discount) * (discount_percentage/100);
        $("#rw_" + row_id + " .DISC_PERCENT").val(discount_percentage);
        $("#rw_" + row_id + " .DISC_AMOUNT").val(row_discount_amt);
        $("#rw_" + row_id + " .DISC").html(row_discount_amt);
        
        if ($(".SALES_INSURANCE").length > 0) {
          let insurance_vat = $("#rw_" + row_id + " .SALES_INSURANCE").val();
          if ($(".unique_sales, .unique_purchase, .unique_salesreturn").length) {
            insurance_amt = (parseFloat(product_amt) * parseFloat(insurance_vat)) / 100;
          }
        }

        if ($(".PUR_INSURANCE").length > 0) {
          let insurance_vat = $("#rw_" + row_id + " .PUR_INSURANCE").val();
          if ($(".unique_sales, .unique_purchase, .unique_salesreturn").length) {
            insurance_amt = (parseFloat(product_amt) * parseFloat(insurance_vat)) / 100;
          }
        }
        
        let tax_amt = parseFloat(product_amt) - parseFloat(scheme1_amount) - parseFloat(scheme2_amount);
        let row_tax_amount = parseFloat(product_amt) -parseFloat(scheme1_amount) -parseFloat(scheme2_amount) - parseFloat(row_discount_amt);
        if ($(".unique_purchase").length) {
          row_tax_amount = parseFloat(product_amt) + parseFloat(insurance_amt) - parseFloat(scheme1_amount) -parseFloat(scheme2_amount) - parseFloat(row_discount_amt);
        }
        let row_tax = 0;
        if(parseFloat(row_tax_amount) > 0 &&  (parseFloat(tax_percent) > 0)){
          row_tax = parseFloat(row_tax_amount) * (parseFloat(tax_percent) / 100);
        }
        $("#rw_" + row_id + " .TAX_AMT").val(row_tax.toFixed(2));
        console.warn("calculate_tax 2",row_tax);

        if (parseFloat($("#rw_" + row_id + " .DAMAGE").val()) > 0) {
          if (parseFloat($("#rw_" + row_id + " .DAMAGE_AMT").val()) > 0) {
            let damage_amt = parseFloat($("#rw_" + row_id + " .DAMAGE_AMT").val())
            tax_amt = damage_amt;
            is_dmg_calculation = 1;
          }
          
          if (parseFloat(tax_amt) > 0) {
            let discount_amt = parseFloat(tax_amt) * (parseFloat(discount_percentage) / 100);
            let difference = parseFloat(tax_amt) - parseFloat(discount_amt);
            $("#rw_" + row_id + " .DISCPER").val(discount_percentage);
            $("#rw_" + row_id + " .DISCAMT").val(discount_amt.toFixed(2));
            $("#rw_" + row_id + " .DISC_PERCENT").val(discount_percentage);
            $("#rw_" + row_id + " .DISC_AMOUNT").val(row_discount_amt.toFixed(2));
            $("#rw_" + row_id + " .DISC").html(row_discount_amt);
            if (is_dmg_calculation == 1) {
              difference = parseFloat(tax_amt);
              final_row_tax_amount = parseFloat(difference) * (parseFloat(tax_percent) / 100);
              $("#rw_" + row_id + " .TAX_AMT").val(final_row_tax_amount.toFixed(2));
              console.warn("calculate_tax 3",final_row_tax_amount);
              //if (parseFloat($("#rw_" + row_id + " .DAMAGE").val()) > 0) {
                //$("#rw_" + row_id + " .TAX_AMT").val(0);
              //}
            }
          }
        }
      }
    });
    updateFooterPart();
  }

  function calculateCustomRoundoff(value) {
    showLoader();
    let final_amount = $("#TEMP_FINAL_AMT").val();
    let round_off = value;
    if (parseFloat(round_off) == 0) {
      $("#FINAL_AMT").val(final_amount);
      $("#ROUND_OFF").val(0);
      hideLoader();
    } else {
      let calculate_amt = parseFloat(final_amount) - parseFloat(round_off);
      if (calculate_amt > 0) {
        $("#FINAL_AMT").val(calculate_amt.toFixed(2));
        $("#ROUND_OFF").val(value);
        hideLoader();
      }
    }
  }

