  <script type="text/javascript">
    function convertToMySQLDate(dateString) {
      const parts = dateString.split('/');
      const month = parts[1];
      const day = parts[0];
      const year = parts[2];
      const mysqlDate = `${year}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`;
      return mysqlDate;
  }
