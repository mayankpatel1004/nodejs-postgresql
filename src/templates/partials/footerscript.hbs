  function getProductQty(qty, row_name, box_kgs = 0) {
    let creditor_debtor_id = 0;
    consoleLog("product qty callled");
    let screen = "";
    if (typeof $("#SUB_AC_DEBTORS").val() !== 'undefined' && $("#SUB_AC_DEBTORS").val() > 0) {
      creditor_debtor_id = $("#SUB_AC_DEBTORS").val();
      screen = "sales";
    }
    if (typeof $("#SUPPLIER_ID").val() !== 'undefined' && $("#SUPPLIER_ID").val() > 0) {
      creditor_debtor_id = $("#SUPPLIER_ID").val();
      screen = "purchase";
    }
    let row_id = document.getElementById(row_name).parentNode.parentNode.id;
    $("#batch_error").html("");
    let batch_id = $("#" + row_id + " .batch").val();
    let data = { qty: qty, batch_id: batch_id, creditor_debtor_id: creditor_debtor_id, "screen": screen }
    $.ajax({
      method: "POST",
      url: "/master/get_combi_product_details",
      data: data
    })
      .done(function (response) {
        let final_qty = convertKgsToQty(response.SALE_UNIT, response.PUR_UNIT, qty, response.PACK, response.CARTON_PACK, box_kgs, response.PRICE_PER);
        $("#" + row_id + " .QTY").val(parseInt(final_qty));
        getProductDetails(final_qty, row_name, box_kgs = 0);
        console.log("getProductQty");
      });
  }

  function convertKgsToQty(sale_unit, purchase_unit, qty, pack, carton_pack, m_qty, price_per) {
    let final_mqty = 0;
    if (m_qty > 0 && pack > 0) {
      final_mqty = parseFloat(m_qty) * parseFloat(pack);
      final_mqty = final_mqty.toFixed(2);
    }
    /*if(sale_unit == 7 && purchase_unit == 10){
      if(qty > 0){
        final_mqty = parseFloat(qty) * parseFloat(pack);
      } else {
        final_mqty = parseFloat(m_qty) * parseFloat(pack);
      }
    }*/
    return final_mqty;
  }

  function convertQtyToKgs(sale_unit, purchase_unit, qty, pack, carton_pack, m_qty, price_per) {
    let final_mqty = 0;
    if (qty > 0 && pack > 0) {
      final_mqty = parseFloat(qty) / parseFloat(pack);
      final_mqty = final_mqty.toFixed(2);
    }
    return final_mqty;
  }

  function getRowProductRate(sale_unit, purchase_unit, qty, pack, sale_rate, purchase_rate, dmg_qty,price_per) {
    //console.log(sale_unit, purchase_unit, qty, pack, sale_rate, purchase_rate, dmg_qty,price_per);
    let total_rate = 0;
    if (parseInt(dmg_qty) > 0) {
      qty = parseInt(dmg_qty);
    }
    if (purchase_rate > 0) {
      total_rate = (parseFloat(purchase_rate)) * parseFloat(qty);
    }
    if (sale_rate > 0) {
      total_rate = (parseFloat(sale_rate)) * parseFloat(qty);
    }
    if (sale_unit == 7 && purchase_unit == 10) {
      if (purchase_rate > 0) {
        total_rate = (parseFloat(purchase_rate) / parseFloat(pack)) * parseFloat(qty);
      }
      if (sale_rate > 0) {
        total_rate = (parseFloat(sale_rate)) * parseFloat(qty);
      }
    }
    console.log("total_rate0",total_rate);
    if(purchase_unit == 10 && !$(".sales_screen").length && !$(".sales_order_screen").length){
      total_rate = (parseFloat(purchase_rate) / parseFloat(pack)) * parseFloat(qty);
    }
    console.log("total_rate",total_rate);
    if(price_per == 10 && parseFloat(sale_rate) > 0){
      total_rate = (parseFloat(sale_rate)/parseFloat(pack)) * parseFloat(qty);
    }
    return total_rate;
  }

  function updateDamageQtyRate(row_id, purchase_sales) {
    let unit = $("#" + row_id + " .PUR_UNIT").val();
    let pack = $("#" + row_id + " .PACK").val();
    let damage_qty = $("#" + row_id + " .DAMAGE").val();
    let tax = $("#" + row_id + " .TAX_PER").html();
    let textbox_pur_sale_rate = $("#" + row_id + " .PUR_RATE").val();

    if (typeof $("#" + row_id + " .PUR_UNIT").val() == 'undefined') {
      unit = $("#rw_" + row_id + " .PUR_UNIT").val();
      pack = $("#rw_" + row_id + " .PACK").val();
      damage_qty = $("#rw_" + row_id + " .DAMAGE").val();
      textbox_pur_sale_rate = $("#rw_" + row_id + " .PUR_RATE").val();
    }

    if (purchase_sales == 'sale') {
      unit = $("#" + row_id + " .SALE_UNIT").val();
      textbox_pur_sale_rate = $("#" + row_id + " .SALES_RATE").val();

      if (typeof $("#" + row_id + " .SALE_UNIT").val() == 'undefined') {
        unit = $("#rw_" + row_id + " .SALE_UNIT").val();
        pack = $("#rw_" + row_id + " .PACK").val();
        damage_qty = $("#rw_" + row_id + " .DAMAGE").val();
      }
    }

    if (purchase_sales == 'purchase') {
      row_id = row_id.startsWith("rw_") ? row_id.slice(3) : row_id;
      unit = $("#" + row_id + " .PUR_UNIT").val();
      textbox_pur_sale_rate = $("#rw_" + row_id + " .PUR_RATE").val();
      if (typeof $("#" + row_id + " .PUR_UNIT").val() == 'undefined') {
        unit = $("#rw_" + row_id + " .PUR_UNIT").val();
        pack = $("#rw_" + row_id + " .PACK").val();
        damage_qty = $("#rw_" + row_id + " .DAMAGE").val();
      }
    }

    let damage_amt = 0;
    let damage_pack = parseFloat(damage_qty) / parseFloat(pack);
    damage_amt = parseFloat(textbox_pur_sale_rate) * parseFloat(damage_qty);
    let calculate_tax = (parseFloat(damage_amt) * parseInt(tax)) / 100;
    $("#rw_" + row_id + " .TAX_AMT").val(calculate_tax);
    $("#rw_" + row_id + " .DAMAGE_AMT").val(damage_amt);
  }

