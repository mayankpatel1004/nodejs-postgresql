  function upDownKeyBatchPopup() {
    const table = document.getElementById("batch_popup_table");
    const rows = table.querySelectorAll("tbody tr");
    let currentIndex = -1;

    document.addEventListener("keydown", function (event) {
      if (event.key === "ArrowDown") {
        if (currentIndex >= 0) {
          rows[currentIndex].classList.remove("highlighted");
          rows[currentIndex].classList.add("normal");
        }
        currentIndex = Math.min(currentIndex + 1, rows.length - 1);
        rows[currentIndex].classList.remove("normal");
        rows[currentIndex].classList.add("highlighted");
      } else if (event.key === "ArrowUp") {
        if (currentIndex >= 0) {
          rows[currentIndex].classList.remove("highlighted");
          rows[currentIndex].classList.add("normal");
        }
        currentIndex = Math.max(currentIndex - 1, 0);
        rows[currentIndex].classList.remove("normal");
        rows[currentIndex].classList.add("highlighted");
      } else if (event.key === "Enter" && currentIndex >= 0) {
        const selectedRow = rows[currentIndex];
        if (parseInt(selectedRow.id) > 0) {
          let split_prod_id = selectedRow.getAttribute("rn").split("_");
          let row_no = split_prod_id[2];
          let qty = $("#QTY_" + row_no).val();
          let damage = $("#DAMAGE_" + row_no).val();
          let replace = $("#REPLACE_" + row_no).val();
          if (qty == 0 || damage == '' || replace == '') {
            fnSetBatch(selectedRow.id, selectedRow.getAttribute("rn"));
          }
        }
      }
    });
  }

  function generateUnique8DigitNumber() {
    // Generate a random number between 10000000 and 99999999
    const min = 10000000;
    const max = 99999999;
    const uniqueNumber = Math.floor(Math.random() * (max - min + 1)) + min;
    return uniqueNumber;
  }

