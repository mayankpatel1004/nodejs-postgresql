  function getDebtorsOutstanding(debtor_id) {
    $(".wrapper_outstanding").addClass('d-none');
    if (debtor_id > 0) {
      let data = { debtor_id: debtor_id }
      $.ajax({
        method: "POST",
        url: "/dataentry/get_debtors_outstanding",
        data: data
      })
        .done(function (response) {
          $(".wrapper_outstanding").removeClass('d-none');
          if (parseFloat(response.sales_amt) > 0) {
            $("#outstanding_sales_amount").html(response.sales_amt);
            $("#outstanding_amount").html(response.outstanding_amount);
            let html = '';
            if (response.arrOutstandingDetails) {
              let outstanding = response.arrOutstandingDetails;
              outstanding.map((item, index) => {
                let outstanding = parseFloat(item.SALES_AMT) - parseFloat(item.COLLECTION_AMT);
                if (parseFloat(outstanding) > 0) {
                  html += '<tr>';
                  html += '<td>' + item.INVOICE_NO + '</td>';
                  html += '<td>' + item.SALES_DATE + '</td>';
                  html += '<td>' + item.ACC_NAME + '</td>';
                  html += '<td>' + outstanding + '</td>';
                  html += '</tr>';
                }
              });
              $("#arr_outstanding_details").html(html);
            }
          } else {
            $("#outstanding_sales_amount").html(0);
            $("#outstanding_amount").html(0);
            $("#arr_outstanding_details").html('<tr><td align="center" colspan="4">No Record Found</td></tr>');
          }
        });
    }
  }

  function editEnableDamageCheckbox() {
    if ($(".REPLACE").length > 0) {
      let allow_check = false;
      $(".REPLACE").map((index, item) => {
        if (parseFloat(item.value) > 0) {
          allow_check = true;
        }
      });
      $(".DAMAGE").map((index, item) => {
        if (parseFloat(item.value) > 0) {
          allow_check = true;
        }
      });
      setTimeout(function () {
        if (allow_check) {
          $("#is_damage").attr("checked", true);
          $(".show_hide_damage").show();
        }
      }, 1000);
    }
  }

