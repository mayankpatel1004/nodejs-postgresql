  function updateEachRowCalculation() {
    showLoader();
    let counter = $('#sampleTable > tbody  > tr').length;
    $('#sampleTable > tbody  > tr').each(function (index, tr) {
      let id = tr.id;
      if (typeof id !== undefined && id != "") {
        let split_id = id.split("_");
        let increment_id = parseInt(split_id[1]) + parseInt(1);
        let percentage = 0;
        let row_name = "SCHEME1_PERCENT_" + increment_id;
        if (parseFloat($("#" + id + " #SCHEME1_PERCENT_" + increment_id).val()) > 0) {
          percentage = $("#" + id + " #SCHEME1_PERCENT_" + increment_id).val();
          getScheme1Amount(percentage, row_name);
        } else {
          getScheme1Amount(0, row_name);
        }
      }
    });
    calculateRoundOff();
  }

  function calculateRoundOff() {

    showLoader();
    $("#ROUND_OFF").val(0);
    let damage_amount = 0
    $(".DAMAGE_AMT").each(function (index, item) {
      if (parseFloat(item.value) > 0) {
        damage_amount += parseFloat(item.value);
      }
    });

    $("#DISCOUNT_AMOUNT").val(0);
    if (parseFloat($("#DISCOUNT_PERCENT").length) > 0) {
      let discount_percentage = $("#DISCOUNT_PERCENT").val();
      let final_gt = parseFloat($("#GROSS_TOTAL").val()) - parseFloat($("#SCHEME1_TOTAL").val()) - parseFloat($("#SCHEME2_TOTAL").val());
      let discount_amount = parseFloat(final_gt) * parseFloat(discount_percentage) / 100;
      if (discount_amount > 0) {
        $("#DISCOUNT_AMOUNT").val(discount_amount.toFixed(2));
      } else {
        $("#DISCOUNT_AMOUNT").val(0);
        $("#DISCOUNT_PERCENT").val(0);
      }
    }

    //TCS Tax = GROSS-SCH1-SCH2-DISC+CESS+CESS_ADDL+INSURANCE+APMC+GST
    let tcs_calc_html = '';
    let tcs_gross_total = parseFloat($("#GROSS_TOTAL").val() > 0 ? $("#GROSS_TOTAL").val() : 0);
    let tcs_sch1 = parseFloat($("#SCHEME1_TOTAL").val() > 0 ? $("#SCHEME1_TOTAL").val() : 0);
    let tcs_sch2 = parseFloat($("#SCHEME2_TOTAL").val() > 0 ? $("#SCHEME2_TOTAL").val() : 0);
    let tcs_disc = parseFloat($("#DISCOUNT_AMOUNT").val() > 0 ? $("#DISCOUNT_AMOUNT").val() : 0);
    let tcs_cess_addl = parseFloat($("#CESS_AMT_ADDL").val() > 0 ? $("#CESS_AMT_ADDL").val() : 0);
    let tcs_insur = parseFloat($("#TAX_AMT_INSURANCE").val() > 0 ? $("#TAX_AMT_INSURANCE").val() : 0);

    let tcs_apmc = parseFloat($("#APMC_TAX_AMT").val() > 0 ? $("#APMC_TAX_AMT").val() : 0);
    let tcs_tax = parseFloat($("#TAX_AMT").val() > 0 ? $("#TAX_AMT").val() : 0);

    let tcs_before_cess = tcs_gross_total - tcs_sch1 - tcs_sch2 - tcs_disc + tcs_cess_addl + tcs_insur + tcs_apmc + tcs_tax;
    
    if ($("#purchase_return_screen").length > 0) {
      tcs_before_cess += damage_amount;
    } else {
      tcs_before_cess -= damage_amount;
    }

    let cess_amt_sign = "";
