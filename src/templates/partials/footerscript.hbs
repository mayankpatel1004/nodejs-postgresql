    if (parseFloat($("#LESS_AMT").val()) > 0) {
      temp_final_amount -= parseFloat($("#LESS_AMT").val());
    }
    let temp_final_amount_decimal = getDecimalPart(temp_final_amount.toFixed(2));
    let temp_final_amount_int = parseInt(temp_final_amount);
    $("#FINAL_AMT").val(0);
    let signature = "";
    if (temp_final_amount_decimal == 0) {
      $("#ROUND_OFF").val(0);
      $(".cl-Final label span").html(" (" + temp_final_amount.toFixed(2) + ")");
      $("#FINAL_AMT").val(signature + temp_final_amount.toFixed(2));
    } else if (temp_final_amount_decimal >= 0.50) {
      let new_final_amount = temp_final_amount_int + 1;
      let added_amt = parseFloat(new_final_amount) - parseFloat(temp_final_amount_int) - parseFloat(temp_final_amount_decimal);
      $("#ROUND_OFF").val("+" + added_amt.toFixed(2));
      document.getElementById('TEMP_FINAL_AMT').value = temp_final_amount.toFixed(2);
      $(".cl-Final label span").html(" (" + temp_final_amount.toFixed(2) + ")");
      $("#FINAL_AMT").val(signature + new_final_amount.toFixed(2));
    } else {
      let new_final_amount = temp_final_amount_int;
      let final_entered_value = '-' + temp_final_amount_decimal.toFixed(2);
      $("#ROUND_OFF").val(final_entered_value.replace('--', '-'));
      document.getElementById('TEMP_FINAL_AMT').value = temp_final_amount.toFixed(2);
      $(".cl-Final label span").html(" (" + temp_final_amount.toFixed(2) + ")");
      $("#FINAL_AMT").val(signature + temp_final_amount_int.toFixed(2));
    }
    hideLoader();
  }

