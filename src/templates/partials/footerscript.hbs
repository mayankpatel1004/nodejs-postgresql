  function updateReverseCalculation(row_id, rate) {

    let SalesReverseCalculation = 0;
    if ($("#SalesReverseCalculation").val() == 1) {
      let badge_rate = parseInt(rate);
      let amount = parseFloat(badge_rate);
      let quantity = parseFloat($("#QTY_" + row_id).val());
      if (parseInt($("#DAMAGE_" + row_id).val()) > 0) {
        quantity = $("#DAMAGE_" + row_id).val();
      }
      let percentage_display = $("#TAX_PER_" + row_id).html();
      let cess_percentage = $("#CESSPER_" + row_id).val();
      let split_perc = percentage_display.split(' ');
      let percentage1 = removeNonNumeric(percentage_display);
      let percentage1_plus_one = ((parseInt(percentage1)) / 100) + parseInt(1);
      let final_reverse_amount = percentage1_plus_one;
      if (parseInt(cess_percentage) > 0) {
        final_reverse_amount = parseFloat(percentage1_plus_one) + (parseFloat(cess_percentage) / 100);
      }

      let calculated_amount = (parseFloat(rate) / parseFloat(final_reverse_amount.toFixed(4)));
      let mrp_price = parseFloat(calculated_amount.toFixed(4)) * parseFloat(quantity);
      let calc_perc = (parseFloat(percentage1) / parseInt(100));
      let tax_amt = parseFloat(mrp_price) * parseFloat(calc_perc);

      if (parseInt($("#DAMAGE_" + row_id).val()) > 0) {
        //$("#DMG_MRP_"+row_id).val(calculated_amount.toFixed(2));
        $("#DAMAGE_AMT_" + row_id).val(mrp_price.toFixed(4));
        $("#DAMAGE_AMT_" + row_id).val(mrp_price.toFixed(4));
      } else {
        $("#MRP_" + row_id).val(mrp_price.toFixed(4));
        let new_amt = parseFloat(calculated_amount) * parseFloat(quantity);
        $("#AMT_" + row_id).val(new_amt.toFixed(4));
      }

      $("#SALES_RATE_" + row_id).val(calculated_amount.toFixed(4));
      $("#TE_RATE_" + row_id).val(rate);
      $("#TAX_AMT_" + row_id).val(tax_amt);

      let percentage = $("#SCHEME1_PERCENT_" + row_id).val();
      let row_name = "SCHEME1_PERCENT_" + row_id;
      let percentage2 = $("#SCHEME2_PERCENT_" + row_id).val();
      let row_name2 = "SCHEME2_PERCENT_" + row_id;
      //if(percentage1 > 0){
      getScheme1Amount(percentage, row_name);
      getScheme2Amount(percentage2, row_name2);
      //}
    } else {
      console.log("UpdateReversalCalculateion");
      getProductDetails($("#QTY_" + row_id).val(), 'QTY_' + row_id);
    }
  }

