  function boxToPcs(pur_sale_qty,box_size){
    let total_box = 0;
    let total_pcs = 0;
    let overall_box = pur_sale_qty;
    if(overall_box){
        const numberString = overall_box.toString();
        const parts = numberString.split('.');
        const total_box = parts[0];
        const total_pcs = parseInt(parseFloat(parts[1])*parseFloat(box_size)/100) || 0;
        let return_box = 0;
        let return_pcs = 0;
        if(parseInt(total_box) > 0){
          return_box = parseInt(total_box);
        }
        if(parseInt(total_pcs) > 0){
          return_pcs = parseInt(total_pcs);
        }
        console.log("return_box",return_box);
        console.log("return_pcs",return_pcs);
        let final = return_box+"/"+return_pcs;
        return final;
    }
  }

