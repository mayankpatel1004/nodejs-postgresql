      + parseFloat($("#TAX_AMT_INSURANCE").val() > 0 ? $("#TAX_AMT_INSURANCE").val() : 0)
      - parseFloat($("#SCHEME1_TOTAL").val() > 0 ? $("#SCHEME1_TOTAL").val() : 0)
      - parseFloat($("#SCHEME2_TOTAL").val() > 0 ? $("#SCHEME2_TOTAL").val() : 0)
      - parseFloat($("#DISCOUNT_AMOUNT").val() > 0 ? $("#DISCOUNT_AMOUNT").val() : 0)
      + parseFloat($("#TAX_AMT").val())
