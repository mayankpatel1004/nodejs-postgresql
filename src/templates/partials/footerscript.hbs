  function fnPrintMultipleInvoices(tab_name) {
    consoleLog("tab_name", tab_name);
    let error = "";
    $(".selection_error").html("");
    let selected_tab = $("#selected_tab").val();
    let invoice_ids = $("#invoice_ids").val();
    let company_id = $("#company_id").val();
    let start_date = $("#start_date").val();
    let end_date = $("#end_date").val();
    let start_date_so  = $("#start_date_so").val();
    let end_date_so    = $("#end_date_so").val();

    let start_date_ret = $("#start_date_ret").val();
    let end_date_ret   = $("#end_date_ret").val();

    let start_date_sc  = $("#start_date_sc").val();
    let end_date_sc    = $("#end_date_sc").val();

    let start_date_pur = $("#start_date_pur").val();
    let end_date_pur   = $("#end_date_pur").val();

    let start_date_pr  = $("#start_date_pr").val();
    let end_date_pr    = $("#end_date_pr").val();

    let start_date_po  = $("#start_date_po").val();
    let end_date_po    = $("#end_date_po").val();

    let selected_template = $("." + tab_name + " .selected_template_class").val();
    if (selected_template == '' || typeof selected_template === 'undefined') {
      error = "Please select invoice template";
    }
    if (invoice_ids == '') {
      error = "Invoice not found";
    }
    if (error != "") {
      $(".selection_error").html(error);
    }
    if (error == '') {
      showLoader();
      let data = {
        company_id: company_id,
        invoice_ids: invoice_ids,
        template: selected_template,
        start_date: start_date,
        end_date: end_date,
        start_date_so: start_date_so,
        end_date_so: end_date_so,
        start_date_ret: start_date_ret,
        end_date_ret: end_date_ret,
        start_date_sc: start_date_sc,
        end_date_sc: end_date_sc,
        start_date_pur: start_date_pur,
        end_date_pur: end_date_pur,
        start_date_pr: start_date_pr,
        end_date_pr: end_date_pr,
        start_date_po: start_date_po,
        end_date_po: end_date_po,
        selected_tab: $("#selected_tab").val(),
        action: "print_invoice"
      };

      $.ajax({
        method: "POST",
        url: '/report/invoice_printing_report',
        data: data
      }).done(function (response) {
        //$('.selected_template_class').val('');
        setTimeout(function () {
          hideLoader();
          if(response.url.length > 1){
            let all_urls = response.url;
            let counter = 0;
            const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));

            for (const url of all_urls) {
              console.log("url",url,"filename",response.filename[counter]);
              downloadPDF(url, response.filename[counter]);
              counter++;
              sleep(2500);
            }
          } else {
            downloadPDF(response.url, response.filename);
          }
          
        }, 2000);
      });
    }
  }
  function downloadPDF(url, fileName) {
    const link = document.createElement('a');
    link.href = url;
    link.download = fileName || 'document.pdf';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }

