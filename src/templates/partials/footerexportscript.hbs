  function fnGetDateRangeInvoices(start_date,end_date,company_id,response_id,response_id2){  
    let data = {start_date: start_date,end_date:end_date,company_id: company_id}
    $.ajax({
        method: "POST",
        url: "/report/get_date_range_invoices",
        data: data
    }).done(function( response ) {
        let items = response.invoices;
        let html = "<option value=''>Invoice</option>";
        $.each(items, function(index, item) {
            html += '<option value="'+item.INVOICE_NO+'">'+item.INVOICE_NO+'</option>';
        });
        $("#"+response_id).html(html);

        $.ajax({
            method: "POST",
            url: "/report/get_date_range_customers",
            data: data
        }).done(function( response ) {
            let items = response.customers;
            let html = "<option value=''>Customers</option>";
            $.each(items, function(index, item) {
                html += '<option value="'+item.ID+'">'+item.ACC_NAME+'</option>';
            });
            console.log(response_id2);
            $("#"+response_id2).html(html);
        }); 

    });
  }

