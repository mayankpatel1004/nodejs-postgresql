      + parseFloat($("#APMC_TAX_AMT").val() > 0 ? $("#APMC_TAX_AMT").val() : 0)
      + parseFloat($("#TCS_TAX").val() > 0 ? $("#TCS_TAX").val() : 0)
      - parseFloat($("#CREDIT_AMT").val() > 0 ? $("#CREDIT_AMT").val() : 0);

    if ($("#sales_return_screen").length > 0) {
      temp_final_amount += damage_amount;
    } else {
      temp_final_amount -= damage_amount;
